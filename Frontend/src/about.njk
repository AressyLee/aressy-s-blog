---
layout: layouts/page.njk
title: 關於我
permalink: /about/
---

{# =========================================================
   SECTION 1 — HERO
   ========================================================= #}
<section class="about-hero" style="background-image: url('{{ aboutData.hero_bg_url }}')">
  <div class="about-hero-overlay"></div>
  <div class="about-hero-content">
    <p class="caption about-hero-label">關於我 / About Me</p>
    <h1 class="about-hero-name">{{ aboutData.name }}</h1>
    <p class="about-hero-tagline">{{ aboutData.tagline }}</p>
  </div>
</section>

{# =========================================================
   SECTION 2 — CORE VALUE
   ========================================================= #}
<section class="about-section about-value">
  <div class="about-value-inner">
    <p class="about-section-label caption">核心價值 / What I Offer</p>
    <p class="about-value-text">{{ aboutData.core_value }}</p>
  </div>
</section>

{# =========================================================
   SECTION 3 — STORY & EXPERTISE
   ========================================================= #}
<section class="about-section about-story">
  <div class="about-story-grid">
    <div class="about-story-text">
      <p class="about-section-label caption">我的故事 / My Story</p>
      <div class="about-story-body">
        {{ aboutData.story_html | safe }}
      </div>
    </div>
    <div class="about-story-photos">
      <div class="about-photo-main" style="background-image: url('{{ aboutData.photo_main_url }}')"></div>
      <div class="about-photo-side">
        <div class="about-photo-sm" style="background-image: url('{{ aboutData.photo_side1_url }}')"></div>
        <div class="about-photo-sm" style="background-image: url('{{ aboutData.photo_side2_url }}')"></div>
      </div>
    </div>
  </div>
</section>

{# =========================================================
   SECTION 4 — PERSONALITY TRAITS
   ========================================================= #}
<section class="about-section about-traits">
  <p class="about-section-label caption">個性特色 / Who I Am</p>
  <div class="about-traits-list">
    {% set traits = aboutData.traits.split("・") %}
    {% for trait in traits %}
      <span class="about-trait-tag">{{ trait }}</span>
    {% endfor %}
  </div>
</section>

{# =========================================================
   SECTION 5 — CTA: CONTACT FORM
   ========================================================= #}
<section class="about-section about-contact">
  <div class="about-contact-inner">
    <div class="about-contact-header">
      <p class="about-section-label caption">聯絡我 / Get In Touch</p>
      <h2 class="about-contact-title">{{ aboutData.cta_title }}</h2>
      <p class="about-contact-subtitle">{{ aboutData.cta_subtitle }}</p>
    </div>
    <form class="about-contact-form" name="contact" method="POST" data-netlify="true" action="/contact-success/">
      <div class="form-row">
        <div class="form-group">
          <label for="contact-name" class="form-label">姓名</label>
          <input type="text" id="contact-name" name="name" class="form-input" placeholder="你的名字" required>
        </div>
        <div class="form-group">
          <label for="contact-email" class="form-label">電子郵件</label>
          <input type="email" id="contact-email" name="email" class="form-input" placeholder="your@email.com" required>
        </div>
      </div>
      <div class="form-group">
        <label for="contact-message" class="form-label">留言</label>
        <textarea id="contact-message" name="message" class="form-textarea" rows="5" placeholder="想說的話，我都認真看..." required></textarea>
      </div>
      <button type="submit" class="form-submit">送出訊息 →</button>
    </form>
  </div>
</section>
