<header class="site-header">
  <a href="/" class="site-logo">{{ site.title }}</a>
  <nav class="site-nav">
    <ul>
      {% for item in navigation %}
        {% if item.disabled %}
          <li><a href="javascript:void(0);" style="cursor: default; opacity: 0.7;" onclick="return false;">{{ item.label }}</a></li>
        {% else %}
          <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {% endif %}
      {% endfor %}
    </ul>
  </nav>
</header>
